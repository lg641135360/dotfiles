#!/bin/sh
# pre-commit — 提交前检查：空白字符 / 脚本语法 / trace 归档
#
# 通过 core.hooksPath 启用：
#   git config core.hooksPath .githooks

set -eu

REPO_ROOT=$(git rev-parse --show-toplevel)

HAS_ERROR=0

# ── ① 空白字符检查 ──────────────────────────────────────────────
git diff --cached --check 2>/dev/null || {
    printf '\033[31m[pre-commit] 空白字符错误，请修复后再提交\033[0m\n' >&2
    HAS_ERROR=1
}

# ── ② 改动脚本语法检查 ──────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -n "$STAGED_FILES" ]; then
    # Shell 脚本
    for f in $(printf '%s\n' "$STAGED_FILES" | grep -E '\.sh$' || true); do
        full="$REPO_ROOT/$f"
        [ -f "$full" ] && bash -n "$full" 2>/dev/null && continue
        printf '\033[31m[pre-commit] shell 语法错误: %s\033[0m\n' "$f" >&2
        HAS_ERROR=1
    done

    # Lua 脚本
    if command -v luajit >/dev/null 2>&1; then
        for f in $(printf '%s\n' "$STAGED_FILES" | grep -E '\.lua$' || true); do
            full="$REPO_ROOT/$f"
            [ -f "$full" ] && luajit -e "assert(loadfile('$full'))" 2>/dev/null && continue
            printf '\033[31m[pre-commit] lua 语法错误: %s\033[0m\n' "$f" >&2
            HAS_ERROR=1
        done
    fi
fi

# ── ③ trace 归档 ────────────────────────────────────────────────
SCRIPT_DIR="$REPO_ROOT/scripts"
if [ -f "$SCRIPT_DIR/archive_trace.ts" ] && command -v npm >/dev/null 2>&1; then
    DRY_RUN_OUTPUT=$(npm --prefix "$SCRIPT_DIR" run archive-trace:dry-run 2>/dev/null) || true
    if ! echo "$DRY_RUN_OUTPUT" | grep -q "No archive needed"; then
        npm --prefix "$SCRIPT_DIR" run archive-trace -- 2>/dev/null || {
            printf '\033[33m[pre-commit] trace 归档失败\033[0m\n' >&2
            HAS_ERROR=1
        }
        git add "$REPO_ROOT/logs/trace.md"
        for f in "$REPO_ROOT"/logs/trace-archive/*.md; do
            [ -f "$f" ] && git add "$f"
        done
    fi
fi

# ── 退出 ─────────────────────────────────────────────────────────
exit "$HAS_ERROR"
