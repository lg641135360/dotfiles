#!/bin/sh
set -eu

BLANK='#00000000'
CLEAR='#ffffff22'
DEFAULT='#00897bE6'
TEXT='#00897bE6'
WRONG='#880000bb'
VERIFYING='#00564dE6'

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

supports_blur() {
    locker=$1
    help_output=$("$locker" --help 2>&1 || true)
    case "$help_output" in
        *--blur*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

screen_geometry() {
    if command_exists xdpyinfo; then
        geometry=$(xdpyinfo 2>/dev/null | awk '$1 == "dimensions:" { print $2; exit }')
        case "$geometry" in
            [0-9]*x[0-9]*)
                printf '%s\n' "$geometry"
                return 0
                ;;
        esac
    fi

    if command_exists xrandr; then
        geometry=$(xrandr --current 2>/dev/null | awk '
            /^Screen 0:/ {
                for (i = 1; i <= NF; i++) {
                    if ($i == "current") {
                        width = $(i + 1)
                        height = $(i + 3)
                        gsub(/[^0-9]/, "", width)
                        gsub(/[^0-9]/, "", height)
                        print width "x" height
                        exit
                    }
                }
            }
        ')
        case "$geometry" in
            [0-9]*x[0-9]*)
                printf '%s\n' "$geometry"
                return 0
                ;;
        esac
    fi

    printf '%s\n' '1920x1080'
}

screen_regions() {
    canvas_width=$1
    canvas_height=$2

    if command_exists xrandr; then
        xrandr --current 2>/dev/null | awk '
            $2 == "connected" {
                for (i = 3; i <= NF; i++) {
                    if ($i ~ /^[0-9]+x[0-9]+[-+][0-9]+[-+][0-9]+$/) {
                        print $i
                        break
                    }
                }
            }
        '
        return 0
    fi

    printf '%sx%s+0+0\n' "$canvas_width" "$canvas_height"
}

generate_themed_lock_image() {
    command_exists python3 || return 1

    geometry=$(screen_geometry)
    width=${geometry%x*}
    height=${geometry#*x}

    case "$width:$height" in
        *[!0-9:]*|:*|*:)
            return 1
            ;;
    esac

    [ "$width" -gt 0 ] && [ "$height" -gt 0 ] || return 1

    regions=$(screen_regions "$width" "$height")
    if [ -z "$regions" ]; then
        regions="${width}x${height}+0+0"
    fi

    layout_id=$(printf '%s\n' "$regions" | awk '
        BEGIN { first = 1 }
        {
            gsub(/[^A-Za-z0-9._+-]/, "-", $0)
            if (!first) {
                printf "_"
            }
            printf "%s", $0
            first = 0
        }
    ')
    [ -n "$layout_id" ] || layout_id="single"

    cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/lock"
    image="$cache_dir/i3lock-catppuccin-${width}x${height}-${layout_id}.png"

    if [ -s "$image" ]; then
        printf '%s\n' "$image"
        return 0
    fi

    mkdir -p "$cache_dir"
    tmp_image="$image.tmp.$$"

    if python3 - "$width" "$height" "$tmp_image" $regions <<'PY'
import math
import re
import struct
import sys
import zlib

width = int(sys.argv[1])
height = int(sys.argv[2])
output = sys.argv[3]
region_specs = sys.argv[4:] or [f"{width}x{height}+0+0"]

base = (30, 30, 46)
mantle = (24, 24, 37)
crust = (17, 17, 27)
mauve = (203, 166, 247)
blue = (137, 180, 250)
teal = (148, 226, 213)
surface = (49, 50, 68)
text = (205, 214, 244)


def lerp(a, b, t):
    return int(a + (b - a) * t)


def mix(c1, c2, t):
    return tuple(lerp(c1[i], c2[i], t) for i in range(3))


def blend(bg, fg, alpha):
    alpha = max(0.0, min(1.0, alpha))
    return tuple(int(bg[i] * (1 - alpha) + fg[i] * alpha) for i in range(3))


def add_glow(color, x, y, cx, cy, radius, glow_color, strength):
    dx = (x - cx) / radius
    dy = (y - cy) / radius
    distance = dx * dx + dy * dy
    if distance >= 1:
        return color
    alpha = (1 - distance) ** 2 * strength
    return blend(color, glow_color, alpha)


def rounded_rect_distance(x, y, cx, cy, half_w, half_h, radius):
    qx = abs(x - cx) - (half_w - radius)
    qy = abs(y - cy) - (half_h - radius)
    ox = max(qx, 0)
    oy = max(qy, 0)
    return math.sqrt(ox * ox + oy * oy) + min(max(qx, qy), 0) - radius


def parse_region(spec):
    match = re.fullmatch(r"(\d+)x(\d+)([-+]\d+)([-+]\d+)", spec)
    if not match:
        return None
    region_w = int(match.group(1))
    region_h = int(match.group(2))
    region_x = int(match.group(3))
    region_y = int(match.group(4))
    if region_w <= 0 or region_h <= 0:
        return None
    # Clamp to the canvas. XRandR normally normalizes enabled outputs into
    # non-negative framebuffer coordinates, but clamping keeps the fallback
    # robust for unusual layouts.
    left = max(0, region_x)
    top = max(0, region_y)
    right = min(width, region_x + region_w)
    bottom = min(height, region_y + region_h)
    if right <= left or bottom <= top:
        return None
    return {
        "x": left,
        "y": top,
        "w": right - left,
        "h": bottom - top,
    }


regions = [region for region in (parse_region(spec) for spec in region_specs) if region]
if not regions:
    regions = [{"x": 0, "y": 0, "w": width, "h": height}]


def make_card(region):
    region_w = region["w"]
    region_h = region["h"]
    card_w = min(max(region_w * 0.32, 280), 920)
    card_h = min(max(region_h * 0.24, 180), 340)
    card_cx = region["x"] + region_w / 2
    card_cy = region["y"] + region_h / 2
    icon_scale = min(max(min(region_w, region_h) / 900, 0.45), 1.4)
    return {
        "card_w": card_w,
        "card_h": card_h,
        "card_cx": card_cx,
        "card_cy": card_cy,
        "card_radius": min(card_w, card_h) * 0.12,
        "icon_scale": icon_scale,
    }


cards = [make_card(region) for region in regions]


def draw_lock_card(color, x, y, card):
    card_w = card["card_w"]
    card_h = card["card_h"]
    card_cx = card["card_cx"]
    card_cy = card["card_cy"]
    card_radius = card["card_radius"]
    icon_scale = card["icon_scale"]

    dist = rounded_rect_distance(x, y, card_cx, card_cy, card_w / 2, card_h / 2, card_radius)
    if dist < 0:
        color = blend(color, (17, 17, 27), 0.52)
        if dist > -3:
            color = blend(color, blue, 0.62)

    # Minimal lock glyph, drawn as geometry so no font dependency is needed.
    glyph_cx = card_cx
    glyph_cy = card_cy - card_h * 0.05
    body_w = 92 * icon_scale
    body_h = 70 * icon_scale
    body_top = glyph_cy + 12 * icon_scale
    body_bottom = body_top + body_h
    body_dist = rounded_rect_distance(
        x,
        y,
        glyph_cx,
        (body_top + body_bottom) / 2,
        body_w / 2,
        body_h / 2,
        12 * icon_scale,
    )
    if body_dist < 0:
        color = blend(color, text, 0.92)

    keyhole_r = 7 * icon_scale
    keyhole_x = glyph_cx
    keyhole_y = body_top + body_h * 0.46
    if (x - keyhole_x) ** 2 + (y - keyhole_y) ** 2 <= keyhole_r ** 2:
        color = blend(color, crust, 0.82)
    if abs(x - keyhole_x) <= 3 * icon_scale and keyhole_y <= y <= keyhole_y + 22 * icon_scale:
        color = blend(color, crust, 0.82)

    shackle_cx = glyph_cx
    shackle_cy = body_top + 4 * icon_scale
    shackle_r = 36 * icon_scale
    shackle_thick = 8 * icon_scale
    circle_delta = abs(math.hypot(x - shackle_cx, y - shackle_cy) - shackle_r)
    if y <= shackle_cy + 2 * icon_scale and circle_delta <= shackle_thick:
        color = blend(color, text, 0.88)
    if abs(x - (shackle_cx - shackle_r)) <= shackle_thick / 2 and shackle_cy <= y <= body_top + 18 * icon_scale:
        color = blend(color, text, 0.88)
    if abs(x - (shackle_cx + shackle_r)) <= shackle_thick / 2 and shackle_cy <= y <= body_top + 18 * icon_scale:
        color = blend(color, text, 0.88)

    return color

rows = []

for y in range(height):
    row = bytearray()
    row.append(0)
    v = y / max(height - 1, 1)
    for x in range(width):
        u = x / max(width - 1, 1)
        color = mix(base, mantle, v * 0.8)
        color = blend(color, crust, max(0, (v - 0.35)) * 0.35)
        color = add_glow(color, x, y, width * 0.18, height * 0.18, max(width, height) * 0.65, mauve, 0.28)
        color = add_glow(color, x, y, width * 0.88, height * 0.22, max(width, height) * 0.72, teal, 0.20)
        color = add_glow(color, x, y, width * 0.58, height * 1.05, max(width, height) * 0.85, blue, 0.22)

        stripe = 0.5 + 0.5 * math.sin((u * 2.6 + v * 1.4) * math.pi)
        color = blend(color, surface, stripe * 0.035)

        for card in cards:
            color = draw_lock_card(color, x, y, card)

        row.extend(color)
    rows.append(bytes(row))


def chunk(kind, data):
    return (
        struct.pack(">I", len(data))
        + kind
        + data
        + struct.pack(">I", zlib.crc32(kind + data) & 0xFFFFFFFF)
    )


png = b"".join(
    [
        b"\x89PNG\r\n\x1a\n",
        chunk(b"IHDR", struct.pack(">IIBBBBB", width, height, 8, 2, 0, 0, 0)),
        chunk(b"IDAT", zlib.compress(b"".join(rows), 6)),
        chunk(b"IEND", b""),
    ]
)

with open(output, "wb") as handle:
    handle.write(png)
PY
    then
        mv "$tmp_image" "$image"
        printf '%s\n' "$image"
        return 0
    fi

    rm -f "$tmp_image"
    return 1
}

lock_with_color_style() {
    locker=$1

    exec "$locker" \
        --insidever-color="$CLEAR"   \
        --ringver-color="$VERIFYING" \
        --insidewrong-color="$CLEAR" \
        --ringwrong-color="$WRONG"   \
        --inside-color="$BLANK"      \
        --ring-color="$DEFAULT"      \
        --line-color="$BLANK"        \
        --separator-color="$DEFAULT" \
        --verif-color="$TEXT"        \
        --wrong-color="$TEXT"        \
        --time-color="$TEXT"         \
        --date-color="$TEXT"         \
        --layout-color="$TEXT"       \
        --keyhl-color="$WRONG"       \
        --bshl-color="$WRONG"        \
        --blur 9                     \
        --clock                      \
        --indicator                  \
        --time-str="%H:%M:%S"        \
        --date-str="%A, %Y-%m-%d"    \
        --keylayout 1
}

lock_with_plain_i3lock() {
    if image=$(generate_themed_lock_image); then
        exec i3lock -n -e -f -i "$image" -c 11111b
    fi

    exec i3lock -n -e -f -c 11111b
}

if command_exists i3lock-color; then
    lock_with_color_style i3lock-color
fi

if command_exists i3lock; then
    if supports_blur i3lock; then
        lock_with_color_style i3lock
    fi

    lock_with_plain_i3lock
fi

if command_exists notify-send; then
    notify-send "Lock screen unavailable" "Install i3lock to enable Awesome lock screen." || true
fi

printf '%s\n' 'Lock screen unavailable: install i3lock.' >&2
exit 127
