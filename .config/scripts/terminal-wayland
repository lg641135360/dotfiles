#!/bin/sh
# Wayland terminal entrypoint for niri. Prefer Alacritty so shared terminal
# styling stays consistent across X11 and Wayland sessions.

if [ -x "$HOME/.nix-profile/bin/alacritty" ]; then
    exec "$HOME/.nix-profile/bin/alacritty" "$@"
fi

if command -v alacritty >/dev/null 2>&1; then
    exec alacritty "$@"
fi

if command -v kitty >/dev/null 2>&1; then
    exec kitty "$@"
fi

if command -v notify-send >/dev/null 2>&1; then
    notify-send "Terminal unavailable" "Install Alacritty or kitty to enable Mod+Return in niri." || true
fi

printf '%s\n' 'Terminal unavailable: install Alacritty or kitty.' >&2
exit 127
