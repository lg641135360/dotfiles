#!/bin/sh
# Region screenshot for Wayland/niri with annotation support.

set -eu

notify() {
    command -v notify-send >/dev/null 2>&1 || return 0
    notify-send "截图" "$1" >/dev/null 2>&1 || true
}

require() {
    command -v "$1" >/dev/null 2>&1 && return 0
    notify "缺少依赖：$1"
    exit 127
}

require grim
require slurp
require satty
require wl-copy

unset GTK_IM_MODULE
export INPUT_METHOD=fcitx
export QT_IM_MODULE=fcitx
export XMODIFIERS=@im=fcitx
export LC_CTYPE=${LC_CTYPE:-zh_CN.UTF-8}

screenshot_dir=${XDG_SCREENSHOTS_DIR:-$HOME/Pictures/Screenshots}
mkdir -p "$screenshot_dir"

timestamp=$(date '+%Y-%m-%d %H-%M-%S')
output_file=$screenshot_dir/Screenshot\ from\ $timestamp.png
tmp_file=

cleanup() {
    [ -n "$tmp_file" ] && rm -f "$tmp_file"
}
trap cleanup EXIT INT TERM

geometry=$(slurp) || exit 0
[ -n "$geometry" ] || exit 0

tmp_file=${TMPDIR:-/tmp}/dotfiles-screenshot-wayland-$$.ppm
grim -g "$geometry" -t ppm "$tmp_file"
satty --filename "$tmp_file" --fullscreen --output-filename "$output_file" \
    --copy-command wl-copy \
    --font-family "Noto Sans CJK SC" \
    --actions-on-enter save-to-file \
    --actions-on-escape exit
