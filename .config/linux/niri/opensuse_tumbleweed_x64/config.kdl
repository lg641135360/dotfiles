// Rikoo niri trial config for Arch Linux x86_64 / Wayland.
// Platform: arch_x64
// Keep AwesomeWM available; this file only defines the niri session behavior.
// Common input/layout/blur/window-rule/binds live in ../common.kdl.
// Validate with: niri validate -c ~/.config/niri/config.kdl

output "DP-3" {
    mode "3840x2160@59.997"
    scale 2
    position x=0 y=0
}

include "../common.kdl"