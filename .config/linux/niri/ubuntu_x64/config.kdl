// Rikoo niri trial config for Ubuntu 24.04 / Wayland.
// Platform: ubuntu_x64
// Keep AwesomeWM available; this file only defines the niri session behavior.
// Common input/layout/blur/window-rule/binds live in ../common.kdl.
// Validate with: niri validate -c ~/.config/niri/config.kdl

output "DP-4" {
    mode "2560x1440@59.951"
    scale 1.25
    position x=0 y=0
}

output "HDMI-A-3" {
    mode "2560x1440@59.951"
    scale 1.25
    position x=2048 y=0
}

include "../common.kdl"
