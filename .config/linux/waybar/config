{
  "layer": "top",
  "position": "top",
  "height": 40,
  "margin-top": 6,
  "margin-left": 8,
  "margin-right": 8,
  "spacing": 4,
  "modules-left": ["niri/workspaces", "custom/separator", "niri/window"],
  "modules-center": ["clock"],
  "modules-right": ["network", "cpu", "memory", "pulseaudio", "tray"],
  "niri/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "focused": "",
      "active": "",
      "urgent": "",
      "default": "",
      "empty": ""
    }
  },
  "niri/window": {
    "format": "{}",
    "max-length": 72,
    "separate-outputs": true
  },
  "custom/separator": {
    "format": "│",
    "tooltip": false
  },
  "tray": {
    "icon-size": 18,
    "spacing": 6
  },
  "clock": {
    "format": "{:%a %m月%d日 %H:%M}",
    "tooltip-format": "{:%Y-%m-%d %A %H:%M}"
  },
  "network": {
    "interval": 1,
    "format-wifi": "↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
    "format-ethernet": "↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
    "format-disconnected": "NET:N/A",
    "tooltip-format": "网络\nSSID：{essid}\n接口：{ifname}\n地址：{ipaddr}/{cidr}\n下载：{bandwidthDownBytes}/s\n上传：{bandwidthUpBytes}/s",
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    "format": "VOL:{volume}%",
    "format-muted": "VOL:MUTE",
    "tooltip-format": "音量：{volume}%",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ -l 1.0",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },
  "cpu": {
    "format": "CPU:{usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "MEM:{percentage}%",
    "tooltip": true
  },
  "battery": {
    "format": "BAT:{capacity}% {icon}",
    "format-charging": "BAT:{capacity}% ",
    "format-plugged": "BAT:{capacity}% ",
    "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
  }
}
