/*******************************************************************************
 * Rofi Theme - Based on yaocc.cc/rofimenu
 *******************************************************************************/

* {
    font: "JetBrainsMono Nerd Font Mono 11.5";
    background-color: transparent;
    text-color: #f1f1f1;
    spacing: 0;
}

window {
    background-color: rgba(34, 62, 79, 0.80);
    width: 680px;
    padding: 0;
    border: 2px solid;
    border-color: #61afef;
    border-radius: 12px;
}

mainbox {
    padding: 20px;
    spacing: 14px;
    border: 0;
    background-color: transparent;
    children: [inputbar, message, listview];
}

inputbar {
    padding: 12px;
    spacing: 10px;
    border: 0;
    border-radius: 8px;
    background-color: #21252b;
    children: [prompt, entry];
}

prompt {
    padding: 0;
    enabled: true;
    text-color: #61afef;
    font: "JetBrainsMono Nerd Font Bold 12";
}

entry {
    expand: true;
    padding: 0;
    placeholder: "搜索...";
    placeholder-color: #565c64;
    cursor: text;
    text-color: #d7dae0;
    font: "Noto Sans CJK SC 11.5";
}

listview {
    columns: 1;
    lines: 8;
    spacing: 4px;
    cycle: false;
    scrollbar: false;
    border: 0;
    background-color: transparent;
}

element {
    padding: 8px;
    spacing: 8px;
    border: 0;
    border-radius: 6px;
    background-color: transparent;
    text-color: #abb2bf;
}

element-text {
    background-color: transparent;
    text-color: inherit;
    vertical-align: 0.5;
    horizontal-align: 0.0;
    padding: 0;
    font: "Noto Sans CJK SC 11.5";
}

element-icon {
    size: 32px;
    padding: 0;
}

element selected {
    background-color: #61afef;
    text-color: #282c34;
}

element selected normal {
    background-color: #61afef;
    text-color: #282c34;
}

element selected active {
    background-color: #61afef;
    text-color: #282c34;
}

element normal.active {
    background-color: #21252b;
    text-color: #61afef;
}

element alternate.active {
    background-color: #21252b;
    text-color: #61afef;
}

message {
    padding: 8px;
    border: 1px solid;
    border-color: #3e4451;
    border-radius: 8px;
    background-color: #21252b;
}

textbox {
    padding: 6px 11px;
    text-color: #abb2bf;
    background-color: transparent;
    font: "Noto Sans CJK SC 11.5";
}
