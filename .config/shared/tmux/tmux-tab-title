#!/bin/sh
set -eu
set -f

MAX_LABEL_LEN=${TMUX_TAB_TITLE_MAX:-28}

strlen() {
    printf '%s\n' "$1" | awk '{ print length }'
}

truncate_tail() {
    value=$1
    max=$2

    [ "$(strlen "$value")" -le "$max" ] && {
        printf '%s\n' "$value"
        return 0
    }

    if [ "$max" -le 3 ]; then
        printf '%s\n' "$value" | awk -v max="$max" '{ print substr($0, 1, max) }'
        return 0
    fi

    printf '%s\n' "$value" | awk -v max="$max" '{ print "..." substr($0, length($0) - (max - 3) + 1) }'
}

normalize_uri_path_and_host() {
    path=$1
    detected_host=''

    case "$path" in
        file://*/*|ssh://*/*)
            rest=${path#*://}
            detected_host=${rest%%/*}
            path=/${rest#*/}
            ;;
    esac

    printf '%s\t%s\n' "$path" "$detected_host"
}

normalize_raw_host() {
    target=$1

    case "$target" in
        *://*) target=${target#*://} ;;
    esac

    target=${target%%/*}
    target=${target%%:*}
    target=${target#*@}

    [ -n "$target" ] || return 1
    printf '%s\n' "$target"
}

is_local_host() {
    case "$1" in
        localhost|localhost.*|127|127.*|0|0.0.0.0)
            return 0
            ;;
    esac

    return 1
}

resolve_ssh_config_alias() {
    host=$1
    config=${HOME:-}/.ssh/config

    [ -r "$config" ] || return 1

    alias=$(
        awk -v target="$host" '
            function invalid_alias(value) {
                return value == "*" || value ~ /[*?]/
            }

            BEGIN {
                wanted = tolower(target)
                alias = ""
                valid = 0
            }

            {
                line = $0
                sub(/^[[:space:]]+/, "", line)
                sub(/[[:space:]]+#.*/, "", line)
                sub(/[[:space:]]+$/, "", line)
                if (line == "" || line ~ /^#/) {
                    next
                }

                field_count = split(line, fields, /[[:space:]]+/)
                key = tolower(fields[1])

                if (key == "host") {
                    alias = ""
                    valid = 0
                    if (field_count == 2 && !invalid_alias(fields[2])) {
                        alias = fields[2]
                        valid = 1
                    }
                    next
                }

                if (key == "match" || key == "include") {
                    alias = ""
                    valid = 0
                    next
                }

                if (valid && key == "hostname" && field_count >= 2) {
                    if (tolower(fields[2]) == wanted) {
                        print alias
                        exit
                    }
                }
            }
        ' "$config"
    )

    [ -n "$alias" ] || return 1
    printf '%s\n' "$alias"
}

ipv4_last_two() {
    host=$1
    value=$(
        printf '%s\n' "$host" |
            awk -F. '
                NF == 4 {
                    for (i = 1; i <= 4; i++) {
                        if ($i !~ /^[0-9]+$/ || $i < 0 || $i > 255) {
                            exit
                        }
                    }
                    print $(NF - 1) "." $NF
                }
            '
    )

    [ -n "$value" ] || return 1
    printf '%s\n' "$value"
}

ipv4_tail_pair() {
    host=$1
    value=$(
        printf '%s\n' "$host" |
            awk -F. '
                NF == 2 {
                    for (i = 1; i <= 2; i++) {
                        if ($i !~ /^[0-9]+$/ || $i < 0 || $i > 255) {
                            exit
                        }
                    }
                    print $1 "." $2
                }
            '
    )

    [ -n "$value" ] || return 1
    printf '%s\n' "$value"
}

display_remote_host() {
    raw=$1
    host=$(normalize_raw_host "$raw" || true)

    [ -n "$host" ] || return 1
    is_local_host "$host" && return 1

    tail_pair=$(ipv4_tail_pair "$host" || true)
    if [ -n "$tail_pair" ]; then
        printf '%s\n' "$tail_pair"
        return 0
    fi

    alias=$(resolve_ssh_config_alias "$host" || true)
    if [ -n "$alias" ]; then
        printf '%s\n' "$alias"
        return 0
    fi

    ipv4=$(ipv4_last_two "$host" || true)
    if [ -n "$ipv4" ]; then
        printf '%s\n' "$ipv4"
        return 0
    fi

    printf '%s\n' "${host%%.*}"
}

trim_trailing_slashes() {
    path=$1

    while [ "$path" != "/" ] && [ "${path%/}" != "$path" ]; do
        path=${path%/}
    done

    printf '%s\n' "$path"
}

shorten_path() {
    path=$1
    max=$2

    [ -n "$path" ] || {
        printf '~\n'
        return 0
    }

    path=$(trim_trailing_slashes "$path")

    case "$path" in
        '.'|'/'|'~')
            printf '~\n'
            return 0
            ;;
    esac

    if [ -n "${HOME:-}" ] && [ "$path" = "$HOME" ]; then
        printf '~\n'
        return 0
    fi

    base=${path##*/}
    dir=${path%/*}

    case "$base" in
        ''|'.'|'/')
            compact='~'
            ;;
        current)
            parent=${dir##*/}
            if [ -n "$parent" ] && [ "$parent" != "$dir" ]; then
                compact="$parent/$base"
            else
                compact=$base
            fi
            ;;
        *)
            compact=$base
            ;;
    esac

    [ -n "$compact" ] || compact='~'

    truncate_tail "$compact" "$max"
}

extract_ssh_host_from_args() {
    args=$1
    set -- $args

    seen_ssh=0
    skip_next=0
    for token do
        if [ "$seen_ssh" -eq 0 ]; then
            command_name=${token##*/}
            [ "$command_name" = ssh ] && seen_ssh=1
            continue
        fi

        if [ "$skip_next" -eq 1 ]; then
            skip_next=0
            continue
        fi

        case "$token" in
            --)
                continue
                ;;
            -[bcDEeFIiJLlmOoQpRSWw])
                skip_next=1
                continue
                ;;
            -*)
                continue
                ;;
            *)
                normalize_raw_host "$token" || true
                return 0
                ;;
        esac
    done
}

detect_ssh_host_from_tty() {
    tty=$1
    [ -n "$tty" ] || return 0

    tty=${tty#/dev/}
    ssh_args=$(
        ps -t "$tty" -o stat= -o comm= -o args= 2>/dev/null |
            awk '$1 ~ /\+/ && ($2 == "ssh" || $0 ~ /(^|[[:space:]\/])ssh[[:space:]]/) { sub(/^[[:space:]]*[^[:space:]]+[[:space:]]+[^[:space:]]+[[:space:]]+/, ""); print; exit }'
    )

    [ -n "$ssh_args" ] || return 0
    extract_ssh_host_from_args "$ssh_args"
}

remote_from_title() {
    title=$1

    case "$title" in
        *@*:*)
            display_remote_host "${title%%:*}" || true
            ;;
        [A-Za-z0-9_.-]*:*)
            display_remote_host "${title%%:*}" || true
            ;;
    esac
}

path_from_title() {
    title=$1

    case "$title" in
        *@*:*) printf '%s\n' "${title#*:}" ;;
        [A-Za-z0-9_.-]*:*) printf '%s\n' "${title#*:}" ;;
    esac
}

format_label() {
    path=$1
    remote_host=${2:-}
    title=${3:-}

    uri_info=$(normalize_uri_path_and_host "$path")
    old_ifs=$IFS
    IFS=$(printf '\t')
    set -- $uri_info
    path=${1:-$path}
    uri_host=${2:-}
    IFS=$old_ifs

    if [ -z "$remote_host" ] && [ -n "$uri_host" ]; then
        remote_host=$(display_remote_host "$uri_host" || true)
    else
        remote_host=$(display_remote_host "$remote_host" || true)
    fi

    if [ -z "$remote_host" ] && [ -n "$title" ]; then
        remote_host=$(remote_from_title "$title" || true)
        title_path=$(path_from_title "$title" || true)
        [ -n "$title_path" ] && path=$title_path
    fi

    if [ -n "$remote_host" ]; then
        host_len=$(strlen "$remote_host")
        path_max=$((MAX_LABEL_LEN - host_len - 1))
        if [ "$path_max" -lt 1 ]; then
            truncate_tail "$remote_host" "$MAX_LABEL_LEN"
            return 0
        fi
        short_path=$(shorten_path "$path" "$path_max")
        printf '%s:%s\n' "$remote_host" "$short_path" | awk -v max="$MAX_LABEL_LEN" '{ if (length($0) > max) print substr($0, 1, max); else print }'
        return 0
    fi

    shorten_path "$path" "$MAX_LABEL_LEN"
}

if [ "${1:-}" = --format ]; then
    shift
    format_label "${1:-}" "${2:-}" "${3:-}"
    exit 0
fi

pane_target=${1:-}
format='#{pane_current_path}	#{pane_title}	#{pane_tty}'

if [ -n "$pane_target" ]; then
    pane_info=$(tmux display-message -p -t "$pane_target" "$format" 2>/dev/null || true)
else
    pane_info=$(tmux display-message -p "$format" 2>/dev/null || true)
fi

if [ -z "$pane_info" ]; then
    printf 'tmux\n'
    exit 0
fi

old_ifs=$IFS
IFS=$(printf '\t')
set -- $pane_info
pane_path=${1:-}
pane_title=${2:-}
pane_tty=${3:-}
IFS=$old_ifs

remote_host=$(detect_ssh_host_from_tty "$pane_tty" || true)
format_label "$pane_path" "$remote_host" "$pane_title"
