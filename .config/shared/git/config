[user]
    name = gang.li02
    email = gang.li02@mthreads.com

[commit]
    template = ~/.config/git/template
    verbose = true

[core]
    autocrlf = input
    whitespace = error
    excludesfile = ~/.config/git/ignore
    editor = nvim
    quotepath = false
    pager = less -R

[init]
    defaultBranch = dev

[status]
    branch = true
    short = true
    showUntrackedFiles = all

[color "status"]
    added = green
    changed = yellow
    untracked = red

[log]
    abbrevCommit = true

[push]
    autoSetupRemote = true

[pull]
    rebase = true

[format]
    pretty = medium

[log]
    date = relative
    graph = true
    decorate = true
    abbrevCommit = true

[alias]
    subinit = submodule update --init --recursive
    subs = submodule status
    st = status
    br = branch
    lg = log
    ci = commit
    cisn = commit -s -n
    co = checkout
    cob = checkout -b
    ps = push
    pl = pull
    plr = pull --rebase
