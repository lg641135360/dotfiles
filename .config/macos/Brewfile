# macOS Homebrew Bundle
# Usage: brew bundle --file ~/.config/macos/Brewfile
#
# 筛选原则：仅收录 macOS 系统默认未预装、且必要的第三方应用。
# 系统自带工具不列入：
#   - zsh  (macOS Catalina+ 默认 shell，/bin/zsh)
#   - git  (Command Line Tools 自带，Homebrew 前置依赖)
#   - zsh-completions / zsh-autosuggestions / zsh-syntax-highlighting
#     (统一由 zinit 从 zsh-users 官方仓库加载，避免重复加载/补全冲突)

# Taps
tap "felixkratz/formulae"
tap "nikitabobko/tap"

# CLI tools
brew "bat"
brew "fd"
brew "fzf"
brew "lsd"
brew "neovim"
brew "ripgrep"
brew "rsync"
brew "tmux"
brew "yazi"
brew "zoxide"

# Terminal
cask "alacritty"

# Window management
brew "nikitabobko/tap/aerospace"
brew "felixkratz/formulae/borders"
